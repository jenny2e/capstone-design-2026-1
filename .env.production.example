# ============================================================
# SKEMA production environment
# 사용법:
#   cp .env.production.example .env.production
#   값을 채운 뒤 docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
# ============================================================

# ── 도메인 / HTTPS ─────────────────────────────────────────────────────────────
# DNS A 레코드를 모두 배포 서버 IP로 연결하세요.
APP_DOMAIN=skema.example.com
API_DOMAIN=api.skema.example.com
ACME_EMAIL=admin@example.com

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
MYSQL_DATABASE=skema_db
MYSQL_USER=skema
MYSQL_PASSWORD=replace-with-a-long-random-db-password

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI API 키 ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── OAuth 소셜 로그인 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── 공개 URL / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=https://skema.example.com
BACKEND_URL=https://api.skema.example.com
NEXT_PUBLIC_API_URL=https://api.skema.example.com
CORS_ORIGINS=https://skema.example.com

# 쉼표로 구분된 관리자 이메일 목록
ADMIN_EMAILS=admin@example.com

# ── Web Push / PWA 푸시 알림 ─────────────────────────────────────────────────
# 생성: python3 scripts/generate-vapid-keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
