# 기본: 텍스트 파일은 LF로 정규화
* text=auto eol=lf

# Shell 스크립트는 반드시 LF (Windows 클론 시 CRLF 변환 방지)
*.sh text eol=lf

# Windows 배치 파일은 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf

# 바이너리 파일은 변환 안 함
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
