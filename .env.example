# ============================================================
# SKEMA — Docker Compose 환경변수
# 사용법: cp .env.example .env  →  값 채우기  →  docker compose up --build
# ============================================================

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=skema_db
MYSQL_USER=skema
MYSQL_PASSWORD=skemapassword

# ── JWT (랜덤 문자열로 교체 필수) ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI API 키 ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── OAuth 소셜 로그인 (선택) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── 프론트엔드 / CORS ────────────────────────────────────────────────────────────
# 브라우저가 접근하는 프론트 URL (CORS 허용 대상)
FRONTEND_URL=http://localhost:3000
# 쉼표 구분으로 여러 origin 허용 가능
CORS_ORIGINS=http://localhost:3000

# 관리자 이메일 목록 (쉼표 구분). 이 계정만 /admin/* 접근 가능
ADMIN_EMAILS=admin@example.com

# 브라우저가 백엔드 API를 호출할 URL (빌드타임 번들에 포함)
# 로컬 Docker: http://localhost:8000  /  운영서버: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# 백엔드 공개 URL — OAuth redirect_uri 생성에 사용
# OAuth 앱 설정의 callback URL과 반드시 일치해야 함
# 로컬: http://localhost:8000  /  운영서버: https://api.yourdomain.com
# 네이버 개발자센터 Callback URL 예: http://localhost:8000/auth/naver/callback
BACKEND_URL=http://localhost:8000

# ── Web Push / PWA 푸시 알림 ─────────────────────────────────────────────────
# 생성: python3 scripts/generate-vapid-keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
