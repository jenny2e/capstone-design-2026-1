# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=skema_db
MYSQL_USER=skema
MYSQL_PASSWORD=skemapassword

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI ────────────────────────────────────────────────────────────────────────
# GPT-4o mini: intent parsing only
OPENAI_API_KEY=sk-...

# Gemini 2.5 Flash: schedule optimization only
GEMINI_API_KEY=AIza...

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# 배포 시 백엔드 CORS에 허용할 브라우저 출처(쉼표 구분). 예: https://app.example.com
CORS_ORIGINS=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-nextauth-secret
