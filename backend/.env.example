# ── 보안 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 데이터베이스 (MySQL, pymysql) ────────────────────────────────────────────
# 로컬 Docker DB: mysql+pymysql://skema:skemapassword@localhost:3306/skema_db
# 클라우드(MySQL SSL 필요 시 쿼리스트링에 ssl_ca 등 추가 — 공급자 문서 참고)
DATABASE_URL=mysql+pymysql://skema:skemapassword@localhost:3306/skema_db

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── OAuth (소셜 로그인) ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── 프론트엔드 / CORS ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# 배포: 프론트 실제 URL을 쉼표로 나열 (예: https://xxx.vercel.app)
CORS_ORIGINS=
