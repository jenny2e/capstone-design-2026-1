# ── 보안 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 데이터베이스 (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/skema_db

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── OAuth (소셜 로그인) ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── 프론트엔드 ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
