# ── 보안 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 데이터베이스 ──────────────────────────────────────────────────────────────
# 로컬 (Auth Proxy): mysql+pymysql://skema:skemapassword@127.0.0.1:3306/skema_db
# Cloud Run:        /cloudsql/프로젝트ID:리전:인스턴스명
DATABASE_URL=mysql+pymysql://skema:skemapassword@127.0.0.1:3306/skema_db
DB_USER=skema
DB_PASSWORD=skemapassword
DB_NAME=skema_db

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── OAuth (소셜 로그인) ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── 프론트엔드 / CORS ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ── 관리자 ────────────────────────────────────────────────────────────────────
# /admin/* 엔드포인트 접근 허용할 이메일 (쉼표 구분)
ADMIN_EMAILS=admin@example.com
